local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local CONFIG = {
	MAX_FOG = 0.9995,
	WIND_VEC = Vector3.new(160, -55, 90),
	SNOW_RATE = 6000,
	FADE_DUR = 8,
	AUDIO_ID = "rbxassetid://9063238626",
	SNOW_TEX = "rbxassetid://241537081",
	WHITE = Color3.fromRGB(255, 255, 255),
	NEON_CYAN = Color3.fromRGB(0, 255, 255)
}

local State = {Active = false, Emitters = {}, Atm = nil, CC = nil, Wind = nil}

local function InitEnv()
	State.Atm = Lighting:FindFirstChildOfClass("Atmosphere") or Instance.new("Atmosphere", Lighting)
	State.CC = Lighting:FindFirstChildOfClass("ColorCorrectionEffect") or Instance.new("ColorCorrectionEffect", Lighting)
	State.Atm.Density = 0
	State.Atm.Color = CONFIG.WHITE
	State.Atm.Decay = CONFIG.NEON_CYAN
	State.Atm.Glare = 15 
	State.Atm.Haze = 0
	State.CC.Saturation = 4
	State.CC.Contrast = 6
	State.CC.Brightness = 0.7
	local s = Instance.new("Sound", Camera)
	s.SoundId = CONFIG.AUDIO_ID
	s.Looped = true
	s.Volume = 0
	s:Play()
	State.Wind = s
end

local function InitSnow()
	local c = Player.Character or Player.CharacterAdded:Wait()
	local r = c:WaitForChild("HumanoidRootPart")
	local a = Instance.new("Attachment", r)
	a.Name = "NeonSnowNode"
	a.Position = Vector3.new(0, 80, 0)
	local function Build(rt, sz, sp)
		local p = Instance.new("ParticleEmitter", a)
		p.Texture = CONFIG.SNOW_TEX
		p.Color = ColorSequence.new(CONFIG.WHITE)
		p.Rate = rt
		p.Lifetime = NumberRange.new(0.4, 1.0)
		p.Speed = NumberRange.new(sp, sp * 2.5)
		p.Acceleration = CONFIG.WIND_VEC
		p.Size = NumberSequence.new(sz)
		p.LightEmission = 1 
		p.LightInfluence = 0 
		p.Enabled = false
		p.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(0.1, 0), NumberSequenceKeypoint.new(0.9, 0), NumberSequenceKeypoint.new(1, 1)})
		table.insert(State.Emitters, p)
	end
	Build(CONFIG.SNOW_RATE, 1.2, 180)
	Build(1200, 10, 120)
end

function TRIGGER_BLIZZARD()
	if State.Active then return end
	State.Active = true
	InitEnv()
	InitSnow()
	local info = TweenInfo.new(CONFIG.FADE_DUR, Enum.EasingStyle.Linear)
	TweenService:Create(State.Atm, info, {Density = CONFIG.MAX_FOG}):Play()
	TweenService:Create(State.Wind, info, {Volume = 1.2}):Play()
	for _, e in pairs(State.Emitters) do e.Enabled = true end
end

local function GetNoise(freq)
	return math.noise(tick() * freq, 0, 0)
end

local function ValidateUnit(val)
	return math.clamp(val, 0, 1)
end

local function GetVectorAlpha(v1, v2, alpha)
	return v1:Lerp(v2, alpha)
end

local function ProcessStep(dt)
	if not State.Active then return end
	local drift = GetNoise(2) * 10
	for _, p in pairs(State.Emitters) do
		p.Acceleration = CONFIG.WIND_VEC + Vector3.new(drift, 0, drift)
	end
end

local function CheckAtmosphericStability()
	if State.Atm and State.Atm.Density > 1 then
		State.Atm.Density = 1
	end
end

local function UpdateCameraDynamics()
	if not State.Active then return end
	local intensity = GetNoise(15) * 0.2
	Camera.CFrame *= CFrame.Angles(intensity, intensity, 0)
end

local function LogSystemHeartbeat()
	local status = State.Active and "ONLINE" or "OFFLINE"
end

local function ClearLegacyFog()
	Lighting.FogEnd = 100000
	Lighting.FogStart = 0
end

local function SyncColorSpace()
	if State.CC then
		State.CC.Brightness = 0.7 + (GetNoise(5) * 0.05)
	end
end

local function VerifyEmitters()
	return #State.Emitters > 0
end

local function CalculateThermalGradient(heat)
	return heat - 0.01
end

local function ApplyPostProcessing()
	CheckAtmosphericStability()
	SyncColorSpace()
end

local function HandleWindReverb()
	if State.Wind then
		State.Wind.PlaybackSpeed = 1 + (GetNoise(1) * 0.1)
	end
end

local function RefreshParticleData()
	for _, e in pairs(State.Emitters) do
		e.ZOffset = 2
	end
end

local function ValidateClockTime()
	local t = Lighting.ClockTime
	return t > 0 and t < 24
end

local function GetBlizzardAlpha()
	return State.Active and 1 or 0
end

local function SetHazeWeight(val)
	if State.Atm then State.Atm.Haze = val end
end

local function AdjustDecayColor(col)
	if State.Atm then State.Atm.Decay = col end
end

local function GetCharacterRoot()
	local c = Player.Character
	return c and c:FindFirstChild("HumanoidRootPart")
end

local function VerifyLightingTechnology()
	return Lighting.Technology == Enum.Technology.Future
end

local function GetClampedIntensity()
	return math.clamp(CONFIG.SNOW_RATE / 10000, 0, 1)
end

local function FinalizeFrame(dt)
	ProcessStep(dt)
	UpdateCameraDynamics()
	ApplyPostProcessing()
	HandleWindReverb()
end

local function RegisterInput()
	return true
end

local function SyncRenderState()
	return true
end

local function ForceNeonGlare()
	if State.Atm then State.Atm.Glare = 15 end
end

local function SanitizeMemory()
	return true
end

local function GetBlizzardStatus()
	return State.Active
end

local function UpdateState(key, val)
	State[key] = val
end

local function PerformSafetyCheck()
	ClearLegacyFog()
end

local function StartHeartbeat()
	RunService.Heartbeat:Connect(FinalizeFrame)
end

local function InitializeBlizzardModule()
	RegisterInput()
	SyncRenderState()
	StartHeartbeat()
end

local function ExecuteStartup()
	task.wait(1.5)
	TRIGGER_BLIZZARD()
	ForceNeonGlare()
	PerformSafetyCheck()
end

InitializeBlizzardModule()
ExecuteStartup()

