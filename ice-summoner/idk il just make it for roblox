local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local SETTINGS = {
	MAX_FOG = 0.98,
	WIND_DIR = Vector3.new(100, -25, 50),
	SNOW_RATE = 4000,
	FADE_TIME = 15
}
local UI = Instance.new("ScreenGui", Player.PlayerGui)
local Frost = Instance.new("ImageLabel", UI)
UI.Name = "EnvironmentSystem"
Frost.Size = UDim2.new(1, 0, 1, 0)
Frost.BackgroundTransparency = 1
Frost.Image = "rbxassetid://131661832"
Frost.ImageColor3 = Color3.fromRGB(180, 210, 255)
Frost.ImageTransparency = 1
local Atm = Lighting:FindFirstChildOfClass("Atmosphere") or Instance.new("Atmosphere", Lighting)
local CC = Lighting:FindFirstChildOfClass("ColorCorrectionEffect") or Instance.new("ColorCorrectionEffect", Lighting)
local Blur = Lighting:FindFirstChildOfClass("BlurEffect") or Instance.new("BlurEffect", Lighting)
local Wind = Instance.new("Sound", Camera)
Atm.Density = 0
Atm.Haze = 0
CC.Saturation = 0
Blur.Size = 0
Wind.Volume = 0
Wind.SoundId = "rbxassetid://9063238626"
Wind.Looped = true
Wind:Play()
local Emitters = {}
local IsBlizzardActive = false
local function CreateEmitter()
	local char = Player.Character or Player.CharacterAdded:Wait()
	local root = char:WaitForChild("HumanoidRootPart")
	local att = Instance.new("Attachment", root)
	att.Name = "BlizzardPivot"
	att.Position = Vector3.new(0, 50, 0)
	local p = Instance.new("ParticleEmitter", att)
	p.Texture = "rbxassetid://241537081"
	p.Rate = SETTINGS.SNOW_RATE
	p.Lifetime = NumberRange.new(1, 2)
	p.Speed = NumberRange.new(70, 120)
	p.Acceleration = SETTINGS.WIND_DIR
	p.Enabled = false
	p.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.2, 0),
		NumberSequenceKeypoint.new(0.8, 0),
		NumberSequenceKeypoint.new(1, 1)
	})
	table.insert(Emitters, p)
end
local function TRIGGER_BLIZZARD()
	IsBlizzardActive = true
	local info = TweenInfo.new(SETTINGS.FADE_TIME, Enum.EasingStyle.Linear)
	TweenService:Create(Atm, info, {Density = SETTINGS.MAX_FOG, Haze = 10}):Play()
	TweenService:Create(Wind, info, {Volume = 0.9}):Play()
	for _, e in pairs(Emitters) do e.Enabled = true end
end
Player.CharacterAdded:Connect(CreateEmitter)
if Player.Character then CreateEmitter() end
local filler = 0
for i = 64, 400 do
	filler = i
end
