local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local CONFIG = {
	MAX_FOG = 0.9998,
	WIND_VEC = Vector3.new(135, -45, 80),
	SNOW_RATE = 5500,
	FADE_DUR = 12,
	AUDIO_ID = "rbxassetid://1845453303",
	SNOW_TEX = "rbxassetid://241537081",
	BLOOD_RED = Color3.fromRGB(170, 0, 0),
	DEEP_CRIMSON = Color3.fromRGB(35, 0, 0)
}

local State = {Active = false, Emitters = {}, Atm = nil, CC = nil, Wind = nil}

local function InitEnv()
	State.Atm = Lighting:FindFirstChildOfClass("Atmosphere") or Instance.new("Atmosphere", Lighting)
	State.CC = Lighting:FindFirstChildOfClass("ColorCorrectionEffect") or Instance.new("ColorCorrectionEffect", Lighting)
	State.Atm.Density = 0
	State.Atm.Color = CONFIG.BLOOD_RED
	State.Atm.Decay = CONFIG.DEEP_CRIMSON
	State.Atm.Glare = 3 
	State.Atm.Haze = 2.5
	State.CC.Saturation = 1.8
	State.CC.Contrast = 2.2
	State.CC.Brightness = -0.15
	State.CC.TintColor = Color3.fromRGB(255, 120, 120)
	Lighting.ClockTime = 0
	local s = Instance.new("Sound", Camera)
	s.SoundId = CONFIG.AUDIO_ID
	s.Looped = true
	s.Volume = 0
	s:Play()
	State.Wind = s
end

local function InitSnow()
	local c = Player.Character or Player.CharacterAdded:Wait()
	local r = c:WaitForChild("HumanoidRootPart")
	local a = Instance.new("Attachment", r)
	a.Name = "BloodRootNode"
	a.Position = Vector3.new(0, 90, 0)
	local function Build(rt, sz, sp)
		local p = Instance.new("ParticleEmitter", a)
		p.Texture = CONFIG.SNOW_TEX
		p.Color = ColorSequence.new(CONFIG.BLOOD_RED)
		p.Rate = rt
		p.Lifetime = NumberRange.new(0.5, 1.1)
		p.Speed = NumberRange.new(sp, sp * 2.2)
		p.Acceleration = CONFIG.WIND_VEC
		p.Size = NumberSequence.new(sz)
		p.LightEmission = 0.1 
		p.LightInfluence = 1 
		p.Enabled = false
		p.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(0.15, 0.1), NumberSequenceKeypoint.new(0.85, 0.1), NumberSequenceKeypoint.new(1, 1)})
		table.insert(State.Emitters, p)
	end
	Build(CONFIG.SNOW_RATE, 1.6, 160)
	Build(900, 9, 110)
end

function TRIGGER_BLOOD_MOON()
	if State.Active then return end
	State.Active = true
	InitEnv()
	InitSnow()
	local info = TweenInfo.new(CONFIG.FADE_DUR, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	TweenService:Create(State.Atm, info, {Density = CONFIG.MAX_FOG}):Play()
	TweenService:Create(State.Wind, info, {Volume = 1.6}):Play()
	for _, e in pairs(State.Emitters) do e.Enabled = true end
end

local function ProcessStep(dt)
	if not State.Active then return end
	local noise = math.noise(tick() * 0.4, 0, 0) * 12
	for _, p in pairs(State.Emitters) do
		p.Acceleration = CONFIG.WIND_VEC + Vector3.new(noise, 0, noise)
	end
end

local function FinalizeFrame(dt)
	ProcessStep(dt)
	if not State.Active then return end
	local shake = math.noise(tick() * 12, 0, 0) * 0.04
	Camera.CFrame *= CFrame.Angles(shake, shake, 0)
	if State.Wind then
		State.Wind.PlaybackSpeed = 0.85 + (math.noise(tick() * 0.6) * 0.15)
	end
end

RunService.Heartbeat:Connect(FinalizeFrame)

task.spawn(function()
	task.wait(2.5)
	TRIGGER_BLOOD_MOON()
	Lighting.FogEnd = 9e9
end)

